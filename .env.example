# =============================================================================
# PCIS P1 Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your credentials.
#
#   cp .env.example .env.local
#
# Never commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Dubai Pulse API (dubaipulse.gov.ae)
# ---------------------------------------------------------------------------
# Register at https://dubaipulse.gov.ae → Developer Portal → Create App
# You'll receive an API Key and API Secret for OAuth2 client_credentials flow.
#
# The API key is prefixed NEXT_PUBLIC_ because the frontend needs it to
# determine whether live mode is available. The secret stays server-side only.

NEXT_PUBLIC_DUBAI_PULSE_API_KEY=your-api-key-here
DUBAI_PULSE_API_SECRET=your-api-secret-here

# ---------------------------------------------------------------------------
# PCIS P1 Backend (Railway)
# ---------------------------------------------------------------------------
# The Hono backend that serves opportunities, matches, and ENGINE results.
# Default points to the Railway production deployment.

NEXT_PUBLIC_P1_API_URL=https://pcisp1-production.up.railway.app

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
# Set to "true" to attempt live API calls before falling back to mock data.
# Requires Dubai Pulse credentials above to be configured.

# NEXT_PUBLIC_USE_LIVE_API=false
